# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# Telegram
BOT_TOKEN=your_bot_token_here

# SOCKS5 proxies (needed if Telegram is blocked on your server).
# Comma-separated. Leave empty for direct connection.
# Format: socks5://user:password@host:port
PROXY_URLS=

# Dev mode: allows X-Bot-Auth header bypass. NEVER set true in production!
DEV_MODE=false

# Domain
DOMAIN=yourdomain.example.com
MINI_APP_URL=https://yourdomain.example.com

# Database
POSTGRES_USER=kickoff
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=kickoff
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
SECRET_KEY=generate_a_strong_random_key_here
BACKEND_URL=http://backend:8000
ALLOWED_ORIGINS=https://yourdomain.example.com

# Frontend (build args)
VITE_API_URL=https://yourdomain.example.com/api
VITE_BOT_USERNAME=your_bot_username
